rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'administrator';
    }

    function isScorer() {
      return isAuthenticated() && getUserRole() in ['administrator', 'scorer'];
    }

    function isCaptain() {
      return isAuthenticated() && getUserRole() in ['administrator', 'captain'];
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Public read collections
    match /teams/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /players/{docId} {
      allow read: if true;
      allow write: if isAdmin() || isCaptain();
    }

    match /fixtures/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /matches/{docId} {
      allow read: if true;
      allow create, update: if isScorer();
      allow delete: if isAdmin();
    }

    match /innings/{docId} {
      allow read: if true;
      allow write: if isScorer();
    }

    match /balls/{docId} {
      allow read: if true;
      allow create: if isScorer();
      allow update, delete: if isScorer();
    }

    match /commentary/{docId} {
      allow read: if true;
      allow write: if isScorer();
    }

    match /statistics/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pointsTable/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leaderboards/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /media/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /notifications/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /awards/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
